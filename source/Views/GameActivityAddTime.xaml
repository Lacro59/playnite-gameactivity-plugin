<UserControl x:Class="GameActivity.Views.GameActivityAddTime"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:CommonPlayniteShared.Converters" 
             xmlns:controls="clr-namespace:CommonPluginsControls.Controls" 
             xmlns:viewmodels="clr-namespace:GameActivity.ViewModels" 
             d:DataContext="{d:DesignInstance Type=viewmodels:GameActivityAddTimeViewModel}"
             mc:Ignorable="d" d:DesignHeight="470" d:DesignWidth="500"
             Background="{DynamicResource WindowBackgourndBrush}">

    <UserControl.Resources>
        <converters:InvertedBoolenConverter x:Key="InvertedBoolenConverter" />
    </UserControl.Resources>

    <Border Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12"   />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12"   />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12"   />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12"   />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12"   />
                <RowDefinition Height="*"    />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{DynamicResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*"   />
                        <ColumnDefinition Width="12"  />
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Style="{DynamicResource ViewColumnLabelText}"
                               Text="{DynamicResource LOCGaDateStart}" />

                    <DatePicker Grid.Column="1" VerticalAlignment="Center"
                                Style="{DynamicResource ModernDatePicker}"
                                IsEnabled="{Binding IsStartLocked, Converter={StaticResource InvertedBoolenConverter}}"
                                SelectedDate="{Binding SelectedDateStart, Mode=TwoWay}" />

                    <controls:TimePicker Grid.Column="3" ShowSeconds="True"
                                         IsEnabled="{Binding IsStartLocked, Converter={StaticResource InvertedBoolenConverter}}"
                                         SelectedTime="{Binding SelectedTimeStart, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{DynamicResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*"   />
                        <ColumnDefinition Width="12"  />
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Style="{DynamicResource ViewColumnLabelText}"
                               Text="{DynamicResource LOCGaDateEnd}" />

                    <DatePicker Grid.Column="1" VerticalAlignment="Center"
                                Style="{DynamicResource ModernDatePicker}"
                                SelectedDate="{Binding SelectedDateEnd, Mode=TwoWay}" />

                    <controls:TimePicker Grid.Column="3" ShowSeconds="True"
                                         SelectedTime="{Binding SelectedTimeEnd, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Grid.Row="4" Style="{DynamicResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <!-- Label         -->
                        <ColumnDefinition Width="*"   />
                        <!-- ComboBox      -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Delete button -->
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <!-- ComboBox + delete -->
                        <RowDefinition Height="Auto" />
                        <!-- Add input         -->
                    </Grid.RowDefinitions>

                    <!-- Label — spans both rows, centered on the whole block -->
                    <TextBlock Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                               Style="{DynamicResource ViewColumnLabelText}"
                               VerticalAlignment="Center"
                               Text="{DynamicResource LOCIsPlayAction}" />

                    <!-- Row 0 — Action selector -->
                    <ComboBox Grid.Column="1" Grid.Row="0" VerticalAlignment="Center"
                              Style="{DynamicResource FilterComboBox}"
                              ItemsSource="{Binding PlayActionsView}"
                              SelectedItem="{Binding SelectedPlayAction, Mode=TwoWay}"
                              DisplayMemberPath="Name">
                        <ComboBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                       Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       Margin="5,3" />
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ComboBox.GroupStyle>
                    </ComboBox>

                    <!-- Row 0 — Delete button, vertically centered on the ComboBox only -->
                    <Button Grid.Column="2" Grid.Row="0"
                            Style="{DynamicResource IconButton}"
                            Content="&#xEE09;"
                            VerticalAlignment="Center"
                            Margin="6,0,0,0"
                            Command="{Binding RemoveCustomActionCommand}"
                            CommandParameter="{Binding SelectedPlayAction.Name}"
                            ToolTip="{DynamicResource LOCRemoveTitle}" />

                    <!-- Row 1 — Add custom action input, aligned with ComboBox left edge -->
                    <StackPanel Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                Margin="0,5,0,0">
                        <TextBox Width="180"
                                 VerticalAlignment="Center"
                                 Text="{Binding CustomActionNameInput, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Style="{DynamicResource IconButton}"
                                Content="&#xEC4B;"
                                VerticalAlignment="Center"
                                Margin="4,0,0,0"
                                Command="{Binding AddCustomActionCommand}"
                                ToolTip="{DynamicResource LOCAddTitle}" />
                    </StackPanel>

                </Grid>
            </Border>

            <Border Grid.Row="6" Style="{DynamicResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*"   />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Style="{DynamicResource ViewColumnLabelText}"
                               Text="{DynamicResource LOCGameActivityPCName}" />
                    <ComboBox Grid.Column="1" VerticalAlignment="Center"
                              Style="{DynamicResource FilterComboBox}"
                              ItemsSource="{Binding ConfigurationOptions}"
                              SelectedItem="{Binding SelectedConfiguration, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName" />
                </Grid>
            </Border>

            <Border Grid.Row="8" Style="{DynamicResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*"   />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{DynamicResource ViewColumnLabelText}"
                               Text="{DynamicResource LOCGameActivityLvGamesElapsedSeconds}" />
                    <TextBlock Grid.Column="1" Style="{DynamicResource ViewColumnValueText}"
                               Text="{Binding ElapsedTimeDisplay}" Foreground="{DynamicResource GlyphBrush}"
                               FontWeight="SemiBold" FontSize="{DynamicResource FontSizeLarge}" />
                </Grid>
            </Border>

            <Border Grid.Row="11" Style="{DynamicResource TopSeparatorBorder}" Padding="0,10,0,0">
                <DockPanel LastChildFill="False">
                    <Button Content="{DynamicResource LOCConfirmLabel}" 
                            DockPanel.Dock="Right"
                            Style="{DynamicResource PrimaryButton}" 
                            Command="{Binding ConfirmCommand}" />
                    
                    <Button Content="{DynamicResource LOCCancelLabel}" 
                            DockPanel.Dock="Right"
                            Style="{DynamicResource SecondaryButton}" 
                            Command="{Binding CancelCommand}" 
                            Margin="0,0,10,0" />
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>