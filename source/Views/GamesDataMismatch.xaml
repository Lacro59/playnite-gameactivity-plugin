<UserControl x:Class="GameActivity.Views.GamesDataMismatch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:GameActivity.Views"
             xmlns:vm="clr-namespace:GameActivity.ViewModels"
             xmlns:controls="clr-namespace:CommonPluginsControls.Controls"
             xmlns:controlsShared="clr-namespace:CommonPluginsShared.Controls"
             xmlns:converters="clr-namespace:CommonPlayniteShared.Converters"
             xmlns:ui="clr-namespace:CommonPluginsShared.UI"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:GamesDataMismatchViewModel}"
             d:DesignHeight="540" d:DesignWidth="1060">

    <UserControl.Resources>

        <!-- ── Converters ───────────────────────────────────────────────────── -->
        <converters:PlayTimeToStringConverter           x:Key="PlayTimeToStringConverter" />
        <BooleanToVisibilityConverter                   x:Key="BoolToVis" />
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvBoolToVis" />

        <!-- ── Section header: GameActivity (cyan accent) ───────────────────── -->
        <!--
            Used on the "GameActivity data" group header and its data sub-columns.
            A 2 px bottom border in GlyphBrush colour visually ties the group together.
        -->
        <Style x:Key="GaSectionHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background"   Value="Transparent" />
            <Setter Property="Foreground"   Value="{DynamicResource GlyphBrush}" />
            <Setter Property="FontWeight"   Value="SemiBold" />
            <Setter Property="FontSize"     Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border BorderThickness="0,0,0,2"
                                BorderBrush="{DynamicResource GlyphBrush}"
                                Background="Transparent"
                                Padding="8,6,8,4">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Section header: Playnite (muted blue accent) ────────────────── -->
        <Style x:Key="PlayniteSectionHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background"   Value="Transparent" />
            <Setter Property="Foreground"   Value="{DynamicResource TextBrushDarker}" />
            <Setter Property="FontWeight"   Value="SemiBold" />
            <Setter Property="FontSize"     Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border BorderThickness="0,0,0,2"
                                BorderBrush="{DynamicResource NormalBorderBrush}"
                                Background="Transparent"
                                Padding="8,6,8,4">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Data column header inside GameActivity section ───────────────── -->
        <!--
            Sortable – keeps the default click behaviour but adds the cyan underline
            so each column is visually anchored to its section.
        -->
        <Style x:Key="GaDataHeaderStyle" TargetType="GridViewColumnHeader" BasedOn="{StaticResource {x:Type GridViewColumnHeader}}">
            <Setter Property="Foreground"       Value="{DynamicResource GlyphBrush}" />
            <Setter Property="BorderThickness"  Value="0,0,0,1" />
            <Setter Property="BorderBrush"      Value="{DynamicResource GlyphBrush}" />
        </Style>

        <!-- ── Data column header inside Playnite section ───────────────────── -->
        <Style x:Key="PlayniteDataHeaderStyle" TargetType="GridViewColumnHeader" BasedOn="{StaticResource {x:Type GridViewColumnHeader}}">
            <Setter Property="Foreground"       Value="{DynamicResource TextBrushDarker}" />
            <Setter Property="BorderThickness"  Value="0,0,0,1" />
            <Setter Property="BorderBrush"      Value="{DynamicResource NormalBorderBrush}" />
        </Style>

        <!-- ── Apply-single icon button ────────────────────────────────────── -->
        <!--
            Compact icon-only button used per row to apply one game.
            Re-uses ModernButton from Common.xaml with tighter padding.
        -->
        <Style x:Key="ApplyIconButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Padding"   Value="6,4" />
            <Setter Property="MinWidth"  Value="0" />
            <Setter Property="Margin"    Value="0" />
            <Setter Property="ToolTip"   Value="{DynamicResource LOCGaGaToPlaynite}" />
        </Style>

    </UserControl.Resources>

    <!-- ════════════════════════════════════════════════════════════════════════
         Root layout: toolbar at the bottom, list fills remaining space.
    ════════════════════════════════════════════════════════════════════════ -->
    <Border Style="{StaticResource TopSeparatorBorder}"
            DockPanel.Dock="Bottom"
            Margin="0,8,0,0">
        
        <DockPanel LastChildFill="True" Margin="10">

            <!-- ── Bottom toolbar ─────────────────────────────────────────────── -->
            <Border DockPanel.Dock="Bottom"
                Margin="0,8,0,0">

                <DockPanel LastChildFill="False" Margin="0,6,0,0">

                    <!-- Close button (right-anchored first so it stays outermost) -->
                    <Button x:Name="PART_BtClose"
                        Content="{DynamicResource LOCCloseLabel}"
                        Style="{StaticResource SecondaryButton}"
                        DockPanel.Dock="Right"
                        Command="{x:Static ui:CommandsWindows.CloseHostWindow}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=UserControl}}" />

                    <!-- Apply-all button – CanExecute drives IsEnabled automatically -->
                    <Button DockPanel.Dock="Right"
                        Margin="0,0,8,0"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ApplyAllCommand}"
                        ToolTip="{DynamicResource LOCGaDataMismatchApplyAllTooltip}">
                        <StackPanel Orientation="Horizontal">
                            <!-- Icon from CommonFont + label -->
                            <TextBlock FontFamily="{DynamicResource CommonFont}"
                                   Text="&#xe90F;&#xe924;&#xe905;"
                                   Style="{DynamicResource BaseTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                            <TextBlock Text="{DynamicResource LOCGaGaToPlaynite}"
                                   Style="{DynamicResource BaseTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                </DockPanel>
            </Border>

            <!-- ── Empty state overlay ────────────────────────────────────────── -->
            <!--
                Shown when no mismatch exists. Lives in a Grid on top of the list
                so the list can stay in the tree and keep its column sizing intact.
            -->
            <Grid>

                <!-- Mismatch list -->
                <controlsShared:ListViewExtend x:Name="PART_Lb"
                                           Style="{StaticResource {x:Type ListView}}"
                                           ItemsSource="{Binding Items}"
                                           FontSize="13"
                                           SortingEnable="True"
                                           SortingDefaultDataName="Name"
                                           SortingSortDirection="Ascending">
                    <ListView.View>
                        <GridView>

                            <!-- ═══ Column: Apply (single game) ══════════════════ -->
                            <GridViewColumn Width="Auto">
                                <GridViewColumnHeader Content="{DynamicResource LOCGaDataMismatchApplyHeader}" Tag="NoSort" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource ApplyIconButton}"
                                            Command="{Binding DataContext.ApplySingleCommand, RelativeSource={RelativeSource AncestorType={x:Type ListView}}}"
                                            CommandParameter="{Binding Id}"
                                            FontFamily="{DynamicResource CommonFont}"
                                            Content="&#xe90F;&#xe924;&#xe905;" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- ═══ Column: Game name (hidden sort key) ══════════ -->
                            <GridViewColumn Width="0" DisplayMemberBinding="{Binding Name}">
                                <GridViewColumnHeader IsHitTestVisible="False" />
                            </GridViewColumn>

                            <!-- ═══ Column: Game name (visible) ══════════════════ -->
                            <GridViewColumn Width="240">
                                <GridViewColumnHeader Content="{DynamicResource LOCGameNameTitle}"
                                                  Tag="Name" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <!-- Clickable hyperlink when the game exists -->
                                            <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                                   Visibility="{Binding GameExist, Converter={StaticResource BoolToVis}}">
                                            <Hyperlink Command="{Binding DataContext.GoToGameCommand, RelativeSource={RelativeSource AncestorType={x:Type ListView}}}"
                                                       CommandParameter="{Binding Id}">
                                                <controls:TextBlockTrimmed Text="{Binding Name}"
                                                                           Style="{DynamicResource ListExtendStyleTextBlock}" />
                                            </Hyperlink>
                                            </TextBlock>
                                            <!-- Plain text when the game no longer exists in the library -->
                                            <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                                   Visibility="{Binding GameExist, Converter={StaticResource InvBoolToVis}}">
                                            <controls:TextBlockTrimmed Text="{Binding Name}"
                                                                       Style="{DynamicResource ListExtendStyleTextBlock}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- ════════════════════════════════════════════════════
                             SECTION: GameActivity data  (cyan accent headers)
                             ════════════════════════════════════════════════════ -->

                            <!-- Section label -->
                            <GridViewColumn Width="auto">
                                <GridViewColumnHeader Content="{DynamicResource LOCGaDataMismatchSectionGa}"
                                                  Style="{StaticResource GaSectionHeaderStyle}"
                                                  Tag="NoSort" />
                                <GridViewColumn.CellTemplate>
                                    <!-- Intentionally empty – visual separator only -->
                                    <DataTemplate>
                                        <TextBlock Style="{DynamicResource BaseTextBlockStyle}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- GA: Session count -->
                            <GridViewColumn Width="110">
                                <GridViewColumnHeader Content="{DynamicResource LOCGaSessionCount}"
                                                  Style="{StaticResource GaDataHeaderStyle}"
                                                  Tag="Count" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Count}"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               HorizontalAlignment="Right" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- GA: Total playtime -->
                            <GridViewColumn Width="120">
                                <GridViewColumnHeader Content="{DynamicResource LOCGaSessionPlayed}"
                                                  Style="{StaticResource GaDataHeaderStyle}"
                                                  Tag="SessionPlaytime" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SessionPlaytime, Converter={StaticResource PlayTimeToStringConverter}}"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- ════════════════════════════════════════════════════
                             SECTION: Playnite data  (muted blue accent headers)
                             ════════════════════════════════════════════════════ -->

                            <!-- Section label -->
                            <GridViewColumn Width="80">
                                <GridViewColumnHeader Content="{DynamicResource LOCGaDataMismatchSectionPlaynite}"
                                                  Style="{StaticResource PlayniteSectionHeaderStyle}"
                                                  Tag="NoSort" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{DynamicResource BaseTextBlockStyle}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- Playnite: Play count -->
                            <GridViewColumn Width="110">
                                <GridViewColumnHeader Content="{DynamicResource LOCPlayCountLabel}"
                                                  Style="{StaticResource PlayniteDataHeaderStyle}"
                                                  Tag="PlayCount" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding PlayCount}"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               HorizontalAlignment="Right" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- Playnite: Total playtime -->
                            <GridViewColumn Width="120">
                                <GridViewColumnHeader Content="{DynamicResource LOCTimePlayed}"
                                                  Style="{StaticResource PlayniteDataHeaderStyle}"
                                                  Tag="Playtime" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Playtime, Converter={StaticResource PlayTimeToStringConverter}}"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                        </GridView>
                    </ListView.View>
                </controlsShared:ListViewExtend>

                <!-- Empty-state card – overlays the list when HasData is false -->
                <Border Style="{StaticResource CardBorder}"
                    Visibility="{Binding EmptyStateVisibility}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="32,20">
                    
                    <TextBlock Text="{DynamicResource LOCGaDataMismatchEmpty}"
                           Style="{DynamicResource BaseTextBlockStyle}"
                           Foreground="{DynamicResource TextBrushDarker}"
                           FontSize="14"
                           HorizontalAlignment="Center" />
                </Border>

            </Grid>
        </DockPanel>

    </Border>
</UserControl>