<UserControl x:Class="GameActivity.Views.GameActivityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:CommonPlayniteShared.Converters"
             xmlns:livechartscommon="clr-namespace:CommonPluginsControls.LiveChartsCommon"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:controlsShared="clr-namespace:CommonPluginsShared.Controls"
             xmlns:commonpluginscontrols="clr-namespace:CommonPluginsControls.Controls"
             xmlns:playnitecontrols="clr-namespace:CommonPluginsControls.PlayniteControls"
             xmlns:commonpluginsshared="clr-namespace:CommonPluginsShared.Converters"
             xmlns:Commonpluginsbehaviors="clr-namespace:CommonPluginsShared.Behaviors"
             xmlns:viewModels="clr-namespace:GameActivity.ViewModels" 
             xmlns:local="clr-namespace:GameActivity.Views"
             mc:Ignorable="d" d:DesignHeight="740" d:DesignWidth="1280"
             d:DataContext="{d:DesignInstance Type=viewModels:GameActivityViewModel}"
             Background="{DynamicResource WindowBackgourndBrush}">

    <UserControl.Resources>
        <converters:PlayTimeToStringConverter x:Key="PlayTimeToStringConverter" />
        <commonpluginsshared:DefaultIconConverter x:Key="DefaultIconConverter" />
        <commonpluginsshared:CompareValueConverter x:Key="CompareValueConverter" />
        <commonpluginsshared:LocalDateTimeConverter x:Key="LocalDateTimeConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter" />

        <Style x:Key="NavTextToggleButton" TargetType="ToggleButton" BasedOn="{StaticResource NavToggleButton}">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Height" Value="33" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontFamily" Value="{DynamicResource CommonFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="DatePickerIconOnly" TargetType="DatePicker" BasedOn="{StaticResource ModernDatePicker}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="MaxWidth" Value="32" />
            <Setter Property="MaxHeight" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Grid Width="32" Height="32">
                            <DatePickerTextBox x:Name="PART_TextBox"
                                               Visibility="Collapsed"
                                               Width="0"
                                               Height="0"
                                               IsHitTestVisible="False"
                                               Focusable="False" />

                            <Button x:Name="PART_Button" Margin="-5"
                                    Style="{DynamicResource NavIconButton}"
                                    Content="&#xEC45;"
                                    FontFamily="{DynamicResource FontIcoFont}"
                                    Width="32"
                                    Height="32"
                                    Focusable="False" />

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=PART_Button}"
                                   StaysOpen="False" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <TabControl Margin="12">
        <TabItem Header="{DynamicResource LOCGameActivity}">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <Grid Name="PART_DataLoad" Grid.RowSpan="3">
                    <ProgressBar IsIndeterminate="True" Width="350" Height="40" />
                    <TextBlock Text="{DynamicResource LOCLoadingLabel}"
                       Style="{DynamicResource BaseTextBlockStyle}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>

                <Border Grid.Row="0" Name="PART_DataTop" Style="{DynamicResource SectionBorder}" Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Navigation -->
                        <Grid Grid.Row="0" Margin="0,0,0,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <ToggleButton x:Name="tbMonthSources" IsChecked="True" Content="{DynamicResource LOCSourcesLabel}" Style="{StaticResource NavTextToggleButton}" Click="ToggleButtonSources_Checked" />
                                <ToggleButton x:Name="tbMonthGenres" IsChecked="False" Content="{DynamicResource LOCGenresLabel}" Style="{StaticResource NavTextToggleButton}" Margin="8,0,0,0" Click="ToggleButtonGenres_Checked" />
                                <ToggleButton x:Name="tbMonthTags" IsChecked="False" Content="{DynamicResource LOCTagsLabel}" Style="{StaticResource NavTextToggleButton}" Margin="8,0,0,0" Click="ToggleButtonTags_Checked" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="&#xe941;" Style="{DynamicResource NavCommonButton}" Click="Button_Click_PrevMonth" />
                                <Label x:Name="activityLabel" Content="{Binding ActivityLabelText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="Bold" MinWidth="50" Margin="12,0" />
                                <Button Content="&#xe942;" Style="{DynamicResource NavCommonButton}" Click="Button_Click_NextMonth" />
                            </StackPanel>

                            <DatePicker HorizontalAlignment="Right" VerticalAlignment="Center" 
                                        Style="{StaticResource DatePickerIconOnly}" 
                                        SelectedDateChanged="DatePicker_SelectedDateChanged"
                                        Commonpluginsbehaviors:DatePickerCalendar.IsMonthYear="True">
                                <DatePicker.CalendarStyle>
                                    <Style TargetType="Calendar" BasedOn="{StaticResource {x:Type Calendar}}">
                                        <Setter Property="SnapsToDevicePixels" Value="True" />
                                        <Setter Property="CalendarDayButtonStyle" Value="{DynamicResource CalendarDayButtonStyle}"/>
                                        <Setter Property="CalendarButtonStyle" Value="{DynamicResource CalendarButtonStyle}"/>
                                        <Setter Property="Background" Value="{DynamicResource PopupBackgroundBrush}" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type Calendar}">
                                                    <StackPanel HorizontalAlignment="Center" Name="PART_Root">
                                                        <CalendarItem Style="{DynamicResource CalendarItemStyle}" Name="PART_CalendarItem" />
                                                        <Button Content="{DynamicResource LOCToday}" 
                                                                Command="Commonpluginsbehaviors:CalendarCommands.SelectToday" 
                                                                CommandParameter="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}}" />
                                                    </StackPanel>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DatePicker.CalendarStyle>
                            </DatePicker>
                        </Grid>

                        <!-- Graphics week -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" x:Name="Col1" />
                                <ColumnDefinition Width="*" x:Name="Col2" />
                                <ColumnDefinition Width="*" x:Name="Col3" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{DynamicResource CardBorder}" Padding="8" Margin="0">
                                <Grid x:Name="gridMonth">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Name="PART_ChartTotalHoursSource_Label" Text="{DynamicResource LOCGameActivityTotalHours}" Style="{DynamicResource SectionHeaderText}" HorizontalAlignment="Center" Grid.Column="1" Grid.Row="0" />

                                    <lvc:CartesianChart x:Name="PART_ChartTotalHoursSource" LegendLocation="none" Grid.Column="1" Grid.Row="1" 
                                                DisableAnimations="True" AnimationsSpeed="10" FontFamily="{DynamicResource CommonFont}">
                                        <lvc:CartesianChart.DataTooltip>
                                            <livechartscommon:CustomerToolTipForTime x:Name="PART_ChartTotalHoursSource_ToolTip" />
                                        </lvc:CartesianChart.DataTooltip>

                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis x:Name="PART_ChartTotalHoursSource_X" ShowLabels="True" 
                                                      FontSize="{DynamicResource FontSize}" FontFamily="{DynamicResource CommonFont}">
                                                <lvc:Axis.Separator>
                                                    <lvc:Separator Step="10" />
                                                </lvc:Axis.Separator>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisX>

                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis x:Name="PART_ChartTotalHoursSource_Y" 
                                                      FontSize="{DynamicResource FontSize}" FontFamily="{DynamicResource FontFamily}" />
                                        </lvc:CartesianChart.AxisY>
                                    </lvc:CartesianChart>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Style="{DynamicResource CardBorder}" Padding="8" Margin="10,0,10,0">
                                <Grid Name="GridDay">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Column="1" Grid.Row="0" x:Name="actLabel" Text="{DynamicResource LOCGameActivityTimeTitle}" Style="{DynamicResource SectionHeaderText}" HorizontalAlignment="Center" />

                                    <lvc:CartesianChart x:Name="PART_ChartHoursByDaySource" LegendLocation="none" Grid.Column="1" Grid.Row="1"  
                                                DisableAnimations="True" AnimationsSpeed="10"
                                                FontSize="{DynamicResource FontSize}" FontFamily="{DynamicResource CommonFont}">
                                        <lvc:CartesianChart.DataTooltip>
                                            <livechartscommon:CustomerToolTipForMultipleTime x:Name="PART_ChartHoursByDaySource_ToolTip" />
                                        </lvc:CartesianChart.DataTooltip>

                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis x:Name="PART_ChartHoursByDaySource_X" ShowLabels="False">
                                                <lvc:Axis.Separator>
                                                    <lvc:Separator Step="1" />
                                                </lvc:Axis.Separator>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis x:Name="PART_ChartHoursByDaySource_Y"
                                              FontSize="{DynamicResource FontSize}" FontFamily="{DynamicResource FontFamily}" />
                                        </lvc:CartesianChart.AxisY>
                                    </lvc:CartesianChart>

                                    <Label Grid.Row="3" FontSize="28" Content=" " />
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" Style="{DynamicResource CardBorder}" Padding="8" Margin="0">
                                <Grid Name="GridWeek">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Column="1" Grid.Row="0" x:Name="acwLabel" Text="{DynamicResource LOCGameActivityTotalHoursByWeeks}" Style="{DynamicResource SectionHeaderText}" HorizontalAlignment="Center" />

                                    <lvc:CartesianChart x:Name="PART_ChartHoursByWeekSource" LegendLocation="none" Grid.Column="1" Grid.Row="1"  
                                                        DisableAnimations="True" AnimationsSpeed="10"
                                                        FontSize="{DynamicResource FontSize}" FontFamily="{DynamicResource CommonFont}">
                                        <lvc:CartesianChart.DataTooltip>
                                            <livechartscommon:CustomerToolTipForMultipleTime x:Name="PART_ChartHoursByWeekSource_ToolTip" />
                                        </lvc:CartesianChart.DataTooltip>

                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis x:Name="PART_ChartHoursByWeekSource_X" ShowLabels="True" FontSize="14" LabelsRotation="160">
                                                <lvc:Axis.Separator>
                                                    <lvc:Separator Step="1" />
                                                </lvc:Axis.Separator>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis x:Name="PART_ChartHoursByWeekSource_Y"
                                              FontSize="{DynamicResource FontSize}" FontFamily="{DynamicResource FontFamily}" />
                                        </lvc:CartesianChart.AxisY>
                                    </lvc:CartesianChart>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Name="PART_DataBottom">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DockPanel>
                        <Border DockPanel.Dock="Top" Style="{DynamicResource FilterCardBorder}" Margin="0,0,0,10">
                            <DockPanel LastChildFill="True">
                                <StackPanel DockPanel.Dock="Left"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="0,0,20,0">
                                    <TextBlock Text="{DynamicResource LOCSearchLabel}"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />

                                    <playnitecontrols:SearchBox x:Name="TextboxSearch"
                                                                Width="200"
                                                                Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                TextChanged="TextboxSearch_TextChanged" />
                                </StackPanel>

                                <DockPanel LastChildFill="True" VerticalAlignment="Center">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                x:Name="FilterSourceButton"
                                                Content="{DynamicResource LOCSourceLabel}"
                                                Style="{DynamicResource SecondaryButton}"
                                                Padding="10,2"
                                                Margin="0"
                                                MinWidth="0"
                                                Click="FilterSourceButton_Click">
                                            <Button.ContextMenu>
                                                <ContextMenu x:Name="FilterSourceMenu"
                                                             DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                             Placement="Bottom"
                                                             MinWidth="180"
                                                             MaxHeight="320">
                                                    <ContextMenu.ItemsSource>
                                                        <Binding Path="FilterSourceItems" />
                                                    </ContextMenu.ItemsSource>
                                                    <ContextMenu.ItemContainerStyle>
                                                        <Style TargetType="{x:Type MenuItem}">
                                                            <Setter Property="Height" Value="30" />
                                                            <Setter Property="Padding" Value="6,2" />
                                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                                            <Setter Property="StaysOpenOnClick" Value="True" />
                                                            <Setter Property="IsCheckable" Value="False" />
                                                            <Setter Property="Tag" Value="{Binding}" />
                                                            <Setter Property="ToolTip" Value="{Binding SourceName}" />
                                                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="FilterSourceMenuItem_PreviewMouseLeftButtonDown" />
                                                            <Setter Property="HeaderTemplate">
                                                                <Setter.Value>
                                                                    <DataTemplate>
                                                                        <CheckBox Name="PART_CbSource"
                                                                                  Tag="{Binding}"
                                                                                  IsChecked="{Binding IsCheck, Mode=TwoWay}"
                                                                                  Focusable="False"
                                                                                  BorderThickness="0"
                                                                                  Background="Transparent"
                                                                                  HorizontalAlignment="Stretch"
                                                                                  HorizontalContentAlignment="Left"
                                                                                  VerticalContentAlignment="Center"
                                                                                  Padding="0"
                                                                                  IsHitTestVisible="False"
                                                                                  Checked="PART_CbSource_Checked"
                                                                                  Unchecked="PART_CbSource_Unchecked">
                                                                            <commonpluginscontrols:TextBlockWithIcon Mode="IconTextFirstWithText"
                                                                                                                     Icon="{Binding ElementName=PART_CbSource, Path=Tag.SourceIcon}"
                                                                                                                     IconText="{Binding ElementName=PART_CbSource, Path=Tag.SourceIconText}"
                                                                                                                     Text="{Binding ElementName=PART_CbSource, Path=Tag.SourceName}" />
                                                                        </CheckBox>
                                                                    </DataTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ContextMenu.ItemContainerStyle>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                        </Button>

                                        <DockPanel Grid.Column="2" LastChildFill="False" VerticalAlignment="Center">
                                            <Button Content="{DynamicResource LOCResetLabel}"
                                                    Style="{DynamicResource SecondaryButton}"
                                                    Margin="0"
                                                    Padding="8,2"
                                                    MinWidth="0"
                                                    Click="FilterSourceReset_Click" />

                                            <commonpluginscontrols:TextBlockTrimmed Style="{DynamicResource BaseTextBlockStyle}"
                                                                                    Margin="8,0,0,0"
                                                                                    VerticalAlignment="Center"
                                                                                    Text="{Binding FilterSourceText}" />
                                        </DockPanel>
                                    </Grid>
                                </DockPanel>
                            </DockPanel>
                        </Border>

                        <controlsShared:ListViewExtend x:Name="lvGames" Style="{StaticResource {x:Type ListView}}"
                                                       SelectionChanged="LvGames_SelectionChanged" FontSize="24" 
                                                       SortingSortDirection="Descending"
                                                       Height="350"
                                                       ItemsSource="{Binding FilteredActivityList}"
                                                       SortingEnable="True" SortingDefaultDataName="GameLastActivity">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="70"
                                                        controlsShared:ListViewColumnOptions.DisableSorting="True">
                                        <GridViewColumnHeader Content="{DynamicResource LOCActionsLabel}" />
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button FontFamily="{DynamicResource CommonFont}" Content="&#xe90f;"
                                                            Tag="{Binding Id}"  Click="Button_Click" HorizontalAlignment="Center" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="50" x:Name="lvGamesIcon"
                                                        controlsShared:ListViewColumnOptions.DisableSorting="True">
                                        <GridViewColumnHeader Name="lvGamesIconHeader" Content="{DynamicResource LOCGameIconTitle}" />
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Image HorizontalAlignment="Center" Height="32" VerticalAlignment="Center" Width="32" 
                                                           Source="{Binding GameIcon, Converter={StaticResource DefaultIconConverter}}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="200"
                                                        controlsShared:ListViewColumnOptions.SortMemberPath="GameTitle">
                                        <GridViewColumnHeader Content="{DynamicResource LOCGameNameTitle}" />
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Visibility="{Binding GameExist, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <Hyperlink Command="{Binding GoToGame}" CommandParameter="{Binding Id}">
                                                                <commonpluginscontrols:TextBlockTrimmed Text="{Binding GameTitle}" Style="{DynamicResource ListExtendStyleTextBlock}" />
                                                            </Hyperlink>
                                                    </TextBlock>
                                                    <TextBlock Visibility="{Binding GameExist, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                                                            <commonpluginscontrols:TextBlockTrimmed Text="{Binding GameTitle}" Style="{DynamicResource ListExtendStyleTextBlock}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="150" DisplayMemberBinding="{Binding TimePlayedInMonth, Converter={StaticResource PlayTimeToStringConverter}}" >
                                        <GridViewColumnHeader Content="{DynamicResource LOCGameActivityTimePlayedInMonth}" />
                                    </GridViewColumn>

                                    <GridViewColumn Width="150" DisplayMemberBinding="{Binding GameLastActivity, Converter={StaticResource LocalDateTimeConverter}}" >
                                        <GridViewColumnHeader Content="{DynamicResource LOCGameActivityLvGamesLastActivity}" />
                                    </GridViewColumn>

                                    <GridViewColumn Width="130"
                                                        controlsShared:ListViewColumnOptions.SortMemberPath="GameElapsedSeconds">
                                        <GridViewColumnHeader Content="{DynamicResource LOCGameActivityLvGamesElapsedSeconds}" />
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding GameElapsedSeconds, Mode=OneWay, Converter={StaticResource PlayTimeToStringConverter}}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                                           Style="{DynamicResource ListExtendStyleLabel}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="75" x:Name="lvGamesSource"
                                                        controlsShared:ListViewColumnOptions.SortMemberPath="GameSourceName">
                                        <GridViewColumnHeader Content="{DynamicResource LOCSourceLabel}" Name="lvGamesSourceHeader" />
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Tag="{Binding}">
                                                    <commonpluginscontrols:TextBlockWithIcon Mode="{Binding RelativeSource={RelativeSource AncestorType=StackPanel}, Path=Tag.TypeStoreIcon}" 
                                                                                                 Icon="{Binding RelativeSource={RelativeSource AncestorType=StackPanel}, Path=Tag.SourceIcon}"
                                                                                                 IconText="{Binding RelativeSource={RelativeSource AncestorType=StackPanel}, Path=Tag.SourceIconText}"
                                                                                                 Style="{DynamicResource ListExtendStyleTextBlock}"
                                                                                                 HorizontalAlignment="Center" VerticalAlignment="Stretch" FontSize="22" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="130" x:Name="lvGamesPcName"
                                                        controlsShared:ListViewColumnOptions.SortMemberPath="PCName">
                                        <GridViewColumnHeader Content="{DynamicResource LOCGameActivityPCName}" Name="lvGamesPcNameHeader" />
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding PCName}" VerticalAlignment="Stretch" Style="{DynamicResource ListExtendStyleLabel}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="130" x:Name="lvGamesPlayAction"
                                                        controlsShared:ListViewColumnOptions.SortMemberPath="GameActionName">
                                        <GridViewColumnHeader Content="{DynamicResource LOCIsPlayAction}" Name="lvGamesPlayActionHeader" />
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding GameActionName}" VerticalAlignment="Stretch" Style="{DynamicResource ListExtendStyleLabel}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn x:Name="lvAvgCpu">
                                        <GridViewColumnHeader Content="{DynamicResource LOCGameActivityAvgCpu}" Name="lvAvgCpuHeader" />
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding AvgCPU}" HorizontalAlignment="Center" VerticalAlignment="Stretch">
                                                    <Label.Style>
                                                        <Style TargetType="Label">
                                                            <Setter Property="Foreground">
                                                                <Setter.Value>
                                                                    <MultiBinding Converter="{StaticResource CompareValueConverter}" ConverterParameter="1">
                                                                        <Binding Path="AvgCPU" />
                                                                        <Binding Path="MaxCPU" />
                                                                        <Binding Path="EnableWarm" />
                                                                    </MultiBinding>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=IsSelected}"
                                                                     Value="True">
                                                                    <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=Foreground}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Label.Style>
                                                </Label>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn x:Name="lvAvgGpu">
                                        <GridViewColumnHeader Content="{DynamicResource LOCGameActivityAvgGpu}" Name="lvAvgGpuHeader" />
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding AvgGPU}" HorizontalAlignment="Center" VerticalAlignment="Stretch">
                                                    <Label.Style>
                                                        <Style TargetType="Label">
                                                            <Setter Property="Foreground">
                                                                <Setter.Value>
                                                                    <MultiBinding Converter="{StaticResource CompareValueConverter}" ConverterParameter="1">
                                                                        <Binding Path="AvgGPU" />
                                                                        <Binding Path="MaxGPU" />
                                                                        <Binding Path="EnableWarm" />
                                                                    </MultiBinding>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=IsSelected}"
                                                                     Value="True">
                                                                    <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=Foreground}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Label.Style>
                                                </Label>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn x:Name="lvAvgRam">
                                        <GridViewColumnHeader Content="{DynamicResource LOCGameActivityAvgRam}" Name="lvAvgRamHeader" />
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding AvgRAM}" HorizontalAlignment="Center" VerticalAlignment="Stretch">
                                                    <Label.Style>
                                                        <Style TargetType="Label">
                                                            <Setter Property="Foreground">
                                                                <Setter.Value>
                                                                    <MultiBinding Converter="{StaticResource CompareValueConverter}" ConverterParameter="1">
                                                                        <Binding Path="AvgRAM" />
                                                                        <Binding Path="MaxRAM" />
                                                                        <Binding Path="EnableWarm" />
                                                                    </MultiBinding>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=IsSelected}"
                                                                     Value="True">
                                                                    <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=Foreground}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Label.Style>
                                                </Label>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn x:Name="lvAvgFps">
                                        <GridViewColumnHeader Content="{DynamicResource LOCGameActivityAvgFps}" Name="lvAvgFpsHeader" />
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding AvgFPS}" HorizontalAlignment="Center" VerticalAlignment="Stretch">
                                                    <Label.Style>
                                                        <Style TargetType="Label">
                                                            <Setter Property="Foreground">
                                                                <Setter.Value>
                                                                    <MultiBinding Converter="{StaticResource CompareValueConverter}" ConverterParameter="0">
                                                                        <Binding Path="AvgFPS" />
                                                                        <Binding Path="MinFPS" />
                                                                        <Binding Path="EnableWarm" />
                                                                    </MultiBinding>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
