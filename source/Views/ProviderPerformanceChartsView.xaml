<UserControl x:Class="GameActivity.Views.ProviderPerformanceChartsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:viewmodels="clr-namespace:GameActivity.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="960"
             d:DataContext="{d:DesignInstance Type=viewmodels:ProviderPerformanceChartsViewModel}"
             Background="{DynamicResource WindowBackgourndBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <!--
      Row 0: hint text
      Row 1: global legend (checkboxes + color swatches), no per-chart legend
      Row 2: 5×2 chart grid
    -->
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding HeaderSubtext}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,6"
                   MaxHeight="40"
                   TextTrimming="CharacterEllipsis"
                   Style="{DynamicResource ViewColumnLabelText}" />

        <Border Grid.Row="1"
                Margin="0,0,0,6"
                Padding="6,4"
                Style="{DynamicResource CardBorder}"
                Visibility="{Binding HasProviderLegend, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="{Binding LegendSectionTitle}"
                           Style="{DynamicResource BaseTextBlockStyle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,0,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ItemsControl Grid.Column="0"
                                  ItemsSource="{Binding ProviderLegendItems}"
                                  Focusable="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewmodels:ProviderVisibilityItem}">
                                <CheckBox Margin="6,2"
                                          VerticalContentAlignment="Center"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="14"
                                                   Height="10"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center"
                                                   RadiusX="1"
                                                   RadiusY="1"
                                                   Fill="{Binding LegendBrush}" />
                                        <TextBlock Text="{Binding ProviderName}"
                                                   VerticalAlignment="Center"
                                                   Style="{DynamicResource BaseTextBlockStyle}"
                                                   Foreground="{DynamicResource TextBrush}" />
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <CheckBox Grid.Column="1"
                              Margin="12,2,0,2"
                              VerticalAlignment="Center"
                              VerticalContentAlignment="Center"
                              Content="{Binding AggregatorModeCaption}"
                              IsChecked="{Binding UseAggregatorSourcesOnly, Mode=TwoWay}" />
                </Grid>
            </StackPanel>
        </Border>

        <ItemsControl Grid.Row="2"
                      ItemsSource="{Binding Charts}"
                      Focusable="False">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="5" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                    <Setter Property="VerticalAlignment" Value="Stretch" />
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type viewmodels:ProviderPerfMetricChartVm}">
                    <Border Margin="3"
                            Padding="4,4,4,2"
                            Style="{DynamicResource CardBorder}">
                        <Grid MinHeight="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="0" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="{Binding Title}"
                                       Style="{DynamicResource BaseTextBlockStyle}"
                                       FontWeight="SemiBold"
                                       FontSize="{DynamicResource FontSize}"
                                       Foreground="{DynamicResource TextBrush}"
                                       Margin="0,0,0,2"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                            <lvc:CartesianChart Grid.Row="1"
                                                MinHeight="0"
                                                VerticalAlignment="Stretch"
                                                HorizontalAlignment="Stretch"
                                                Series="{Binding Series}"
                                                LegendLocation="None"
                                                DisableAnimations="True"
                                                AnimationsSpeed="0:0:0.1">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title=""
                                              Labels="{Binding Labels}"
                                              LabelsRotation="0"
                                              ShowLabels="False"
                                              FontSize="10"
                                              FontFamily="{DynamicResource FontFamily}">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Step="1" IsEnabled="False" />
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title=""
                                              MinValue="{Binding AxisYMin}"
                                              MaxValue="{Binding AxisYMax}"
                                              ShowLabels="True"
                                              FontSize="10"
                                              FontFamily="{DynamicResource FontFamily}">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator />
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
