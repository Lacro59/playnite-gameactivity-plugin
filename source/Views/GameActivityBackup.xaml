<UserControl x:Class="GameActivity.Views.GameActivityBackup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:GameActivity.Views"
             xmlns:converters="clr-namespace:CommonPluginsShared.Converters"
             xmlns:converters1="clr-namespace:CommonPlayniteShared.Converters"
             xmlns:controls="clr-namespace:GameActivity.Controls"
             mc:Ignorable="d" d:DesignHeight="420" d:DesignWidth="820">

    <UserControl.Resources>
        <converters:LocalDateConverter x:Key="LocalDateConverter" />
        <converters:LocalDateTimeConverter x:Key="LocalDateTimeConverter" />
        <converters1:PlayTimeToStringConverter x:Key="PlayTimeToStringConverter" />
    </UserControl.Resources>

    <!-- Root layout: content above, action bar pinned at bottom -->
    <Border Style="{StaticResource TopSeparatorBorder}"
            DockPanel.Dock="Bottom"
            Margin="0,8,0,0">

        <DockPanel Margin="16" LastChildFill="True">

            <!-- ═══════════════════════════════════════════════════════════
             ACTION BAR — pinned to bottom, docked first so it stays
             visible regardless of content height
             ═══════════════════════════════════════════════════════════ -->
            <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource NormalBorderBrush}"
                Margin="0,12,0,0">
                <DockPanel KeyboardNavigation.TabNavigation="Local"
                       LastChildFill="False"
                       Margin="0,10,0,0">

                    <!-- Destructive action on the right, far from Add -->
                    <Button Name="PART_BtRemove"
                        TabIndex="2"
                        Content="{DynamicResource LOCRemoveTitle}"
                        DockPanel.Dock="Right"
                        Style="{DynamicResource WarningButton}"
                        Command="{Binding CmdRemove}" />

                    <Button Name="PART_BtClose"
                        TabIndex="1"
                        Content="{DynamicResource LOCCancelLabel}"
                        DockPanel.Dock="Right"
                        Style="{DynamicResource SecondaryButton}"
                        Command="{Binding CmdClose}" />

                    <Button Name="PART_BtAdd"
                        TabIndex="0"
                        Content="{DynamicResource LOCAddTitle}"
                        DockPanel.Dock="Right"
                        Style="{DynamicResource PrimaryButton}"
                        Command="{Binding CmdAdd}" />
                </DockPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════
             MAIN CONTENT AREA
             ═══════════════════════════════════════════════════════════ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Cover image — fixed width as requested -->
                    <ColumnDefinition Width="auto" />
                    <!-- Separator spacer -->
                    <ColumnDefinition Width="20" />
                    <!-- Metadata + chart column -->
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ── Cover image ─────────────────────────────────────── -->
                <Border Grid.Column="0"
                    CornerRadius="6"
                    ClipToBounds="True"
                    Width="250"
                    Height="250"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{DynamicResource PanelSeparatorBrush}">
                    <Image Stretch="UniformToFill"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       StretchDirection="Both"
                       Source="{Binding Cover}"
                       RenderOptions.BitmapScalingMode="Fant" />
                </Border>

                <!-- ── Right column: title + cards + chart ─────────────── -->
                <StackPanel Grid.Column="2" Orientation="Vertical">

                    <!-- Game title -->
                    <TextBlock Text="{Binding Name, FallbackValue='Game Name'}"
                           Style="{DynamicResource BaseTextBlockStyle}"
                           FontSize="{DynamicResource FontSizeLargest}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,0,0,14" />

                    <!-- ── Card 1: Backup session info ─────────────────── -->
                    <Border Style="{DynamicResource SectionBorder}" Margin="0,0,0,10">
                        <StackPanel>
                            <!-- Card header -->
                            <TextBlock Text="{DynamicResource LOCGaBackupDataInfo}"
                                   Style="{DynamicResource BaseTextBlockStyle}"
                                   FontSize="{DynamicResource FontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource GlyphBrush}"
                                   Margin="0,0,0,8" />

                            <!-- Date session row -->
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Left"
                                       Style="{DynamicResource BaseTextBlockStyle}"
                                       Text="{DynamicResource LOCGaDateSession}"
                                       Foreground="{DynamicResource TextBrushDarker}"
                                       Width="160" />
                                <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                       Text="{Binding DateSession, FallbackValue='--', Converter={StaticResource LocalDateTimeConverter}}"
                                       Foreground="{DynamicResource TextBrush}" />
                            </DockPanel>

                            <!-- Session duration row -->
                            <DockPanel Margin="0,6,0,0">
                                <TextBlock DockPanel.Dock="Left"
                                       Style="{DynamicResource BaseTextBlockStyle}"
                                       Text="{DynamicResource LOCGameActivityLvGamesElapsedSeconds}"
                                       Foreground="{DynamicResource TextBrushDarker}"
                                       Width="160" />
                                <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                       Text="{Binding ElapsedSeconds, FallbackValue='--', Converter={StaticResource PlayTimeToStringConverter}}"
                                       Foreground="{DynamicResource TextBrush}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── Card 2: Current Playnite game state ─────────── -->
                    <Border Style="{DynamicResource SectionBorder}" Margin="0,0,0,10">
                        <StackPanel>
                            <!-- Card header -->
                            <TextBlock Text="{DynamicResource LOCGaCurrentGameState}"
                                   Style="{DynamicResource BaseTextBlockStyle}"
                                   FontSize="{DynamicResource FontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource GlyphBrush}"
                                   Margin="0,0,0,8" />

                            <!-- Last played row -->
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Left"
                                       Style="{DynamicResource BaseTextBlockStyle}"
                                       Text="{DynamicResource LOCLastPlayedLabel}"
                                       Foreground="{DynamicResource TextBrushDarker}"
                                       Width="160" />
                                <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                       Text="{Binding DateLastPlayed, FallbackValue='--', Converter={StaticResource LocalDateTimeConverter}}"
                                       Foreground="{DynamicResource TextBrush}" />
                            </DockPanel>

                            <!-- Total playtime row -->
                            <DockPanel Margin="0,6,0,0">
                                <TextBlock DockPanel.Dock="Left"
                                       Style="{DynamicResource BaseTextBlockStyle}"
                                       Text="{DynamicResource LOCTimePlayed}"
                                       Foreground="{DynamicResource TextBrushDarker}"
                                       Width="160" />
                                <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                       Text="{Binding Playtime, FallbackValue='--', Converter={StaticResource PlayTimeToStringConverter}}"
                                       Foreground="{DynamicResource TextBrush}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── Chart log (preserved as-is per spec) ────────── -->
                    <StackPanel Name="PART_ChartLogContener" Margin="0,4,0,0" Height="160">
                        <controls:PluginChartLog IgnoreSettings="True" AxisLimit="10" DisableAnimations="True" />
                    </StackPanel>

                </StackPanel>
            </Grid>
        </DockPanel>

    </Border>
</UserControl>