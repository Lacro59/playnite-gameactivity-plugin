<UserControl x:Class="GameActivity.Views.GameActivityViewSingle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:GameActivity.Controls"
             xmlns:controlsShared="clr-namespace:CommonPluginsShared.Controls"
             xmlns:converters="clr-namespace:CommonPlayniteShared.Converters"
             xmlns:commonpluginsshared="clr-namespace:CommonPluginsShared.Converters"
             xmlns:commonpluginscontrols="clr-namespace:CommonPluginsControls.Controls"
             xmlns:viewmodels="clr-namespace:GameActivity.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:GameActivityViewSingleViewModel}"
             mc:Ignorable="d" d:DesignHeight="760" d:DesignWidth="1400"
             Background="{DynamicResource WindowBackgourndBrush}">

    <!--
        All converters needed by this view.
        No style is declared locally: every style comes from Common.xaml or Constants.xaml.
          NavIconButton    — 32×32 icon button, FontIcoFont    (Common.xaml)
          NavCommonButton  — 32×32 icon button, CommonFont     (Common.xaml)
          NavToggleButton  — 32×32 toggle button, CommonFont   (Common.xaml)
          ViewColumnLabelText — muted label in stat rows        (Common.xaml)
          StatValue        — SemiBold value in stat rows        (Common.xaml)
          SectionBorder / CardBorder — container styles         (Common.xaml)
    -->
    <UserControl.Resources>
        <commonpluginsshared:CompareValueConverter  x:Key="CompareValueConverter" />
        <commonpluginsshared:LocalDateTimeConverter x:Key="LocalDateTimeConverter" />
        <converters:PlayTimeToStringConverter       x:Key="PlayTimeToStringConverter" />
        <BooleanToVisibilityConverter               x:Key="BooleanToVisibilityConverter" />
        <commonpluginsshared:IndexConverter         x:Key="IndexConverter" />
        <converters:InvertedBoolenConverter         x:Key="InvertedBoolenConverter" />
    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════
         Root: 2-column layout
           Col 0  — Cover + stats + session list (left panel)
           Col 2  — Time chart (top) + log chart (bottom) (right panel)
         ═══════════════════════════════════════════════════════════════════ -->
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <!-- Left panel: fixed width to fit ListView columns comfortably -->
            <ColumnDefinition Width="550" />
            <ColumnDefinition Width="12" />
            <!-- Right panel: takes all remaining space for charts -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════
             COLUMN 0 — Cover + stats + toolbar + list
             ═══════════════════════════════════════════════ -->
        <DockPanel Grid.Column="0" LastChildFill="True">

            <!-- ── Top cluster: cover + title + stats ── -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">

                <!-- Cover image card -->
                <Border DockPanel.Dock="Left"
                        Style="{DynamicResource CardBorder}"
                        Margin="0,0,10,0"
                        Padding="0"
                        CornerRadius="8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.35" Color="Black" />
                    </Border.Effect>
                    <Image Name="PART_ImageCover"
                           Width="220"
                           Height="220"
                           Stretch="Uniform"
                           StretchDirection="Both"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="Fant"
                           Source="{Binding CoverImage}"
                           Margin="8" />
                </Border>

                <!-- Game title -->
                <TextBlock DockPanel.Dock="Top"
                           Style="{DynamicResource BaseTextBlockStyle}"
                           Text="{Binding GameDisplayName, FallbackValue='Game Name'}"
                           FontSize="{DynamicResource FontSizeLarger}"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,0,0,10" />

                <!-- Stats card -->
                <Border DockPanel.Dock="Top"
                        Style="{DynamicResource SectionBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Average play-time per session -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Style="{DynamicResource ViewColumnLabelText}"
                                   Text="{DynamicResource LOCGameActivityAvgPerSession}" />
                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Style="{DynamicResource StatValue}"
                                   Text="{Binding TimeAvg}" />

                        <!-- Most recent activity (relative date) -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Style="{DynamicResource ViewColumnLabelText}"
                                   Text="{DynamicResource LOCGameActivityRecentActivity}" />
                        <TextBlock Grid.Row="2" Grid.Column="2"
                                   Style="{DynamicResource StatValue}"
                                   Text="{Binding RecentActivity}" />

                        <Separator Grid.Row="3" Grid.ColumnSpan="3"
                                   Background="{DynamicResource NormalBorderBrush}"
                                   Margin="0,2" />

                        <!-- First / Last session sub-grid -->
                        <Grid Grid.Row="4" Grid.ColumnSpan="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- First session date -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Style="{DynamicResource ViewColumnLabelText}"
                                       Text="{DynamicResource LOCGameActivityFirstSession}" />
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Style="{DynamicResource StatValue}"
                                       Text="{Binding FirstSession}" />

                            <!-- First session duration -->
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Style="{DynamicResource ViewColumnLabelText}"
                                       Text="{DynamicResource LOCGameActivityLvGamesElapsedSeconds}" />
                            <TextBlock Grid.Row="2" Grid.Column="2"
                                       Style="{DynamicResource StatValue}"
                                       Text="{Binding FirstSessionElapsedTime}" />

                            <!-- Last session date -->
                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Style="{DynamicResource ViewColumnLabelText}"
                                       Text="{DynamicResource LOCGameActivityLastSession}" />
                            <TextBlock Grid.Row="4" Grid.Column="2"
                                       Style="{DynamicResource StatValue}"
                                       Text="{Binding LastSession}" />

                            <!-- Last session duration -->
                            <TextBlock Grid.Row="6" Grid.Column="0"
                                       Style="{DynamicResource ViewColumnLabelText}"
                                       Text="{DynamicResource LOCGameActivityLvGamesElapsedSeconds}" />
                            <TextBlock Grid.Row="6" Grid.Column="2"
                                       Style="{DynamicResource StatValue}"
                                       Text="{Binding LastSessionElapsedTime}" />
                        </Grid>
                    </Grid>
                </Border>
            </DockPanel>

            <!-- ── Session list toolbar ── -->
            <Border DockPanel.Dock="Top"
                    Style="{DynamicResource SectionBorder}"
                    Padding="8,6"
                    Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <!-- Add new session -->
                    <Button Name="PART_BtAdd"
                            Content="&#xe971;"
                            Style="{DynamicResource NavIconButton}"
                            FontFamily="{DynamicResource FontIcoFont}"
                            FontSize="{DynamicResource FontSizeLarger}"
                            Command="{Binding AddActivityCommand}"
                            ToolTip="{DynamicResource LOCGaAddNewGameSession}" />

                    <!-- Merge sessions -->
                    <Button Name="PART_BtMerged"
                            Content="&#xe987;"
                            Style="{DynamicResource NavCommonButton}"
                            Command="{Binding MergeActivityCommand}"
                            ToolTip="{DynamicResource LOCGaMergeSession}" />
                </StackPanel>
            </Border>

            <!-- ── Session ListView (LastChildFill) ── -->
            <Border Style="{DynamicResource SectionBorder}" Padding="0" Margin="0,0,0,0">
                <controlsShared:ListViewExtend x:Name="lvSessions"
                                               Style="{StaticResource {x:Type ListView}}"
                                               SelectionChanged="LvSessions_SelectionChanged"
                                               FontSize="{DynamicResource FontSize}"
                                               SortingSortDirection="Descending"
                                               SortingEnable="True"
                                               SelectedItem="{Binding SelectedSession}"
                                               SortingDefaultDataName="GameLastActivity"
                                               ItemsSource="{Binding SessionItems}">
                    <ListView.View>
                        <GridView>

                            <!-- Date -->
                            <GridViewColumn Width="auto" 
                                            DisplayMemberBinding="{Binding GameLastActivity, Converter={StaticResource LocalDateTimeConverter}}">
                                <GridViewColumnHeader Content="{DynamicResource LOCGameActivityLvGamesLastActivity}" />
                            </GridViewColumn>

                            <!-- Duration (human-readable) -->
                            <GridViewColumn Width="auto"
                                            controlsShared:ListViewColumnOptions.SortMemberPath="GameElapsedSeconds">
                                <GridViewColumnHeader Content="{DynamicResource LOCGameActivityLvGamesElapsedSeconds}" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Label Content="{Binding GameElapsedSeconds, Mode=OneWay,
                                                   Converter={StaticResource PlayTimeToStringConverter}}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Stretch"
                                               Style="{DynamicResource ListExtendStyleLabel}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- PC Name -->
                            <GridViewColumn Width="auto" x:Name="lvGamesPcName">
                                <GridViewColumnHeader Content="{DynamicResource LOCGameActivityPCName}"
                                                      Name="lvGamesPcNameHeader" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Label Content="{Binding PCName}"
                                               VerticalAlignment="Stretch"
                                               Style="{DynamicResource ListExtendStyleLabel}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- Play action -->
                            <GridViewColumn Width="auto" x:Name="lvGamesPlayAction">
                                <GridViewColumnHeader Content="{DynamicResource LOCIsPlayAction}"
                                                      Name="lvGamesPlayActionHeader" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Label Content="{Binding GameActionName}"
                                               VerticalAlignment="Stretch"
                                               Style="{DynamicResource ListExtendStyleLabel}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- Source icon -->
                            <GridViewColumn Width="auto" x:Name="lvGamesSource">
                                <GridViewColumnHeader Content="{DynamicResource LOCSourceLabel}"
                                                      Tag="listGameSourceName"
                                                      Name="lvGamesSourceHeader" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Tag="{Binding}">
                                            <commonpluginscontrols:TextBlockWithIcon
                                                Mode="{Binding RelativeSource={RelativeSource AncestorType=StackPanel}, Path=Tag.TypeStoreIcon}"
                                                Icon="{Binding RelativeSource={RelativeSource AncestorType=StackPanel}, Path=Tag.SourceIcon}"
                                                IconText="{Binding RelativeSource={RelativeSource AncestorType=StackPanel}, Path=Tag.SourceIconText}"
                                                Style="{DynamicResource ListExtendStyleTextBlock}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Stretch"
                                                FontSize="{DynamicResource FontSizeLarger}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- ── Hardware monitoring columns ── -->

                            <!-- CPU % -->
                            <GridViewColumn x:Name="lvAvgCpu" Width="auto">
                                <GridViewColumnHeader Content="{DynamicResource LOCGameActivityAvgCpu}"
                                                      Name="lvAvgCpuHeader" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Label Content="{Binding AvgCPU}"
                                               HorizontalAlignment="Center" VerticalAlignment="Stretch">
                                            <Label.Style>
                                                <Style TargetType="Label">
                                                    <Setter Property="Foreground">
                                                        <Setter.Value>
                                                            <MultiBinding Converter="{StaticResource CompareValueConverter}" ConverterParameter="1">
                                                                <Binding Path="AvgCPU" />
                                                                <Binding Path="MaxCPU" />
                                                                <Binding Path="EnableWarm" />
                                                            </MultiBinding>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=Foreground}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Label.Style>
                                        </Label>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- GPU % -->
                            <GridViewColumn x:Name="lvAvgGpu" Width="auto">
                                <GridViewColumnHeader Content="{DynamicResource LOCGameActivityAvgGpu}"
                                                      Name="lvAvgGpuHeader" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Label Content="{Binding AvgGPU}"
                                               HorizontalAlignment="Center" VerticalAlignment="Stretch">
                                            <Label.Style>
                                                <Style TargetType="Label">
                                                    <Setter Property="Foreground">
                                                        <Setter.Value>
                                                            <MultiBinding Converter="{StaticResource CompareValueConverter}" ConverterParameter="1">
                                                                <Binding Path="AvgGPU" />
                                                                <Binding Path="MaxGPU" />
                                                                <Binding Path="EnableWarm" />
                                                            </MultiBinding>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=Foreground}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Label.Style>
                                        </Label>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- RAM % -->
                            <GridViewColumn x:Name="lvAvgRam" Width="auto">
                                <GridViewColumnHeader Content="{DynamicResource LOCGameActivityAvgRam}"
                                                      Name="lvAvgRamHeader" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Label Content="{Binding AvgRAM}"
                                               HorizontalAlignment="Center" VerticalAlignment="Stretch">
                                            <Label.Style>
                                                <Style TargetType="Label">
                                                    <Setter Property="Foreground">
                                                        <Setter.Value>
                                                            <MultiBinding Converter="{StaticResource CompareValueConverter}" ConverterParameter="1">
                                                                <Binding Path="AvgRAM" />
                                                                <Binding Path="MaxRAM" />
                                                                <Binding Path="EnableWarm" />
                                                            </MultiBinding>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=Foreground}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Label.Style>
                                        </Label>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- FPS — ConverterParameter=0 means warn when BELOW threshold -->
                            <GridViewColumn x:Name="lvAvgFps" Width="auto">
                                <GridViewColumnHeader Content="{DynamicResource LOCGameActivityAvgFps}"
                                                      Name="lvAvgFpsHeader" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Label Content="{Binding AvgFPS}"
                                               HorizontalAlignment="Center" VerticalAlignment="Stretch">
                                            <Label.Style>
                                                <Style TargetType="Label">
                                                    <Setter Property="Foreground">
                                                        <Setter.Value>
                                                            <MultiBinding Converter="{StaticResource CompareValueConverter}" ConverterParameter="0">
                                                                <Binding Path="AvgFPS" />
                                                                <Binding Path="MinFPS" />
                                                                <Binding Path="EnableWarm" />
                                                            </MultiBinding>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=Foreground}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Label.Style>
                                        </Label>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- CPU temp -->
                            <GridViewColumn x:Name="lvAvgCpuT" Width="auto">
                                <GridViewColumnHeader Content="{DynamicResource LOCGameActivityAvgCpuT}"
                                                      Name="lvAvgCpuTHeader" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Label Content="{Binding AvgCPUT}"
                                               HorizontalAlignment="Center" VerticalAlignment="Stretch">
                                            <Label.Style>
                                                <Style TargetType="Label">
                                                    <Setter Property="Foreground">
                                                        <Setter.Value>
                                                            <MultiBinding Converter="{StaticResource CompareValueConverter}" ConverterParameter="1">
                                                                <Binding Path="AvgCPUT" />
                                                                <Binding Path="MaxCPUT" />
                                                                <Binding Path="EnableWarm" />
                                                            </MultiBinding>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=Foreground}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Label.Style>
                                        </Label>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- GPU temp -->
                            <GridViewColumn x:Name="lvAvgGpuT" Width="auto">
                                <GridViewColumnHeader Content="{DynamicResource LOCGameActivityAvgGpuT}"
                                                      Name="lvAvgGpuTHeader" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Label Content="{Binding AvgGPUT}"
                                               HorizontalAlignment="Center" VerticalAlignment="Stretch">
                                            <Label.Style>
                                                <Style TargetType="Label">
                                                    <Setter Property="Foreground">
                                                        <Setter.Value>
                                                            <MultiBinding Converter="{StaticResource CompareValueConverter}" ConverterParameter="1">
                                                                <Binding Path="AvgGPUT" />
                                                                <Binding Path="MaxGPUT" />
                                                                <Binding Path="EnableWarm" />
                                                            </MultiBinding>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=Foreground}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Label.Style>
                                        </Label>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- CPU power -->
                            <GridViewColumn x:Name="lvAvgCpuP" Width="auto">
                                <GridViewColumnHeader Content="{DynamicResource LOCGameActivityAvgCpuP}"
                                                      Name="lvAvgCpuPHeader" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Label Content="{Binding AvgCPUP}"
                                               HorizontalAlignment="Center" VerticalAlignment="Stretch">
                                            <Label.Style>
                                                <Style TargetType="Label">
                                                    <Setter Property="Foreground">
                                                        <Setter.Value>
                                                            <MultiBinding Converter="{StaticResource CompareValueConverter}" ConverterParameter="1">
                                                                <Binding Path="AvgCPUP" />
                                                                <Binding Path="MaxCPUT" />
                                                                <Binding Path="EnableWarm" />
                                                            </MultiBinding>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=Foreground}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Label.Style>
                                        </Label>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- GPU power -->
                            <GridViewColumn x:Name="lvAvgGpuP" Width="auto">
                                <GridViewColumnHeader Content="{DynamicResource LOCGameActivityAvgGpuP}"
                                                      Name="lvAvgGpuPHeader" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Label Content="{Binding AvgGPUP}"
                                               HorizontalAlignment="Center" VerticalAlignment="Stretch">
                                            <Label.Style>
                                                <Style TargetType="Label">
                                                    <Setter Property="Foreground">
                                                        <Setter.Value>
                                                            <MultiBinding Converter="{StaticResource CompareValueConverter}" ConverterParameter="1">
                                                                <Binding Path="AvgGPUT" />
                                                                <Binding Path="MaxGPUT" />
                                                                <Binding Path="EnableWarm" />
                                                            </MultiBinding>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}, Path=Foreground}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Label.Style>
                                        </Label>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- Action buttons (delete / edit) -->
                            <GridViewColumn Width="auto">
                                <GridViewColumnHeader Content="{DynamicResource LOCActionsLabel}" />
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Delete activity -->
                                            <Button Content="&#x1f5d9;"
                                                    Style="{DynamicResource NavIconButton}"
                                                    FontFamily="{DynamicResource FontIcoFont}"
                                                    Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl},
                                                                      Path=DataContext.DeleteActivityCommand}"
                                                    CommandParameter="{Binding GameLastActivity}"
                                                    ToolTip="{DynamicResource LOCRemoveTitle}" />
                                            
                                            <!-- Edit activity -->
                                            <Button Content="&#xef10;"
                                                    Style="{DynamicResource NavIconButton}"
                                                    FontFamily="{DynamicResource FontIcoFont}"
                                                    Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl},
                                                                      Path=DataContext.EditActivityCommand}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="{DynamicResource LOCEditGame}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                        </GridView>
                    </ListView.View>
                </controlsShared:ListViewExtend>
            </Border>
        </DockPanel>

        <!-- ═══════════════════════════════════════════════
             COLUMN 2 — Time chart (top) + log chart + nav toolbar + PC config
             ═══════════════════════════════════════════════ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <!-- Time chart: 2/3 of vertical space -->
                <RowDefinition Height="*" />
                <RowDefinition Height="8" />
                <!-- Log chart: 1/3 of vertical space -->
                <RowDefinition x:Name="RowLogSection" Height="1.2*" />
                <RowDefinition Height="8" />
                <!-- PC config expander -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Time chart ── -->
            <Border Grid.Row="0" Style="{DynamicResource SectionBorder}" Padding="8">
                <Grid Name="PART_ChartTimeContainer">
                    <controls:PluginChartTime IgnoreSettings="True"
                                              DisableAnimations="True"
                                              LabelsRotation="True"
                                              AxisLimit="15" />
                </Grid>
            </Border>

            <!-- ── Log chart ── -->
            <Border Grid.Row="2"
                    Name="PART_LogSection"
                    Style="{DynamicResource SectionBorder}"
                    Padding="8">
                <controls:PluginChartLog IgnoreSettings="True"
                                         AxisLimit="10"
                                         DisableAnimations="True" />
            </Border>

            <!-- ── PC Config — ModernExpanderStyle variante C ──────────────────────────
                 Style="{DynamicResource ModernExpanderStyle}" remplace l'Expander natif.
                 Header   : string affiché en SemiBold dans le header (ContentPresenter).
                 Tag      : subtitle affiché en TextBrushDarker à droite du titre.
                            Passer une binding sur une propriété du ViewModel pour le rendre
                            dynamique (ex. nom du PC sélectionné). Mettre "" pour le masquer.
                 IsExpanded : lié TwoWay au ToggleButton ButtonShowConfig de la toolbar.
                 ──────────────────────────────────────────────────────────────────────── -->
            <Expander Grid.Row="8"
                      Style="{DynamicResource ModernExpanderStyle}"
                      Header="{DynamicResource LOCMenuConfigurationTitle}"
                      Tag="{Binding PcSubtitle}"
                      IsExpanded="{Binding ElementName=ButtonShowConfig, Path=IsChecked, Mode=TwoWay}">

                <!-- Content area — padding géré par Expander.Padding (défaut 10,8 dans le style) -->
                <Grid Margin="0,8,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- PC Name -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Style="{DynamicResource ViewColumnLabelText}"
                               Text="{DynamicResource LOCGameActivityPCName}" />
                    <TextBlock Grid.Row="0" Grid.Column="2"
                               Style="{DynamicResource ViewColumnValueText}"
                               Text="{Binding PcName}" />

                    <!-- OS -->
                    <TextBlock Grid.Row="0" Grid.Column="4"
                               Style="{DynamicResource ViewColumnLabelText}"
                               Text="OS" />
                    <TextBlock Grid.Row="0" Grid.Column="6"
                               Style="{DynamicResource ViewColumnValueText}"
                               Text="{Binding OsName}" />

                    <!-- CPU — full width -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Style="{DynamicResource ViewColumnLabelText}"
                               Text="CPU" />
                    <TextBlock Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="5"
                               Style="{DynamicResource ViewColumnValueText}"
                               Text="{Binding CpuName}" />

                    <!-- GPU -->
                    <TextBlock Grid.Row="4" Grid.Column="0"
                               Style="{DynamicResource ViewColumnLabelText}"
                               Text="GPU" />
                    <TextBlock Grid.Row="4" Grid.Column="2"
                               Style="{DynamicResource ViewColumnValueText}"
                               Text="{Binding GpuName}" />

                    <!-- RAM -->
                    <TextBlock Grid.Row="4" Grid.Column="4"
                               Style="{DynamicResource ViewColumnLabelText}"
                               Text="RAM" />
                    <TextBlock Grid.Row="4" Grid.Column="6"
                               Style="{DynamicResource ViewColumnValueText}"
                               Text="{Binding RamUsage}" />
                </Grid>

            </Expander>

        </Grid>
    </Grid>
</UserControl>