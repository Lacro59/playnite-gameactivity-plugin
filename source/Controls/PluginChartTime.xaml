<controls:PluginUserControlExtend
        xmlns:controls="clr-namespace:CommonPluginsShared.Controls"
        x:Class="GameActivity.Controls.PluginChartTime"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:GameActivity.Controls"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf" 
        xmlns:controls1="clr-namespace:CommonPluginsControls.Controls"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:PluginChartTimeDataContext}"
        MinHeight="{Binding RelativeSource={RelativeSource AncestorType=ContentControl}, Path=MinHeight}"
        Height="{Binding ChartTimeHeight}"
        MaxHeight="{Binding RelativeSource={RelativeSource AncestorType=ContentControl}, Path=MaxHeight}">

    <controls:PluginUserControlExtend.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </controls:PluginUserControlExtend.Resources>

    <!--
        Layout: 2 rows.
          Row 0 — navigation bar (Auto, collapses to 0 when ShowNavBar=False)
          Row 1 — chart          (*,  unchanged)
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
        </Grid.RowDefinitions>

        <!-- ===== Row 0 — Navigation bar ===== -->
        <!--
            ShowNavBar DP controls visibility.
            ShowAllData: nav bar toggles it; PluginChartTime.cs mirrors it back via NavBar_ShowAllToggled.
            NavLabel: updated by GetActivityForGamesChartByWeek (e.g. "Week 12"); empty in day mode.
            PageSize: bound to DataContext.PageSize (resolved in SetDefaultDataContext as
                      AxisLimit > 0 ? AxisLimit : ChartTimeCountAbscissa).
        -->
        <controls1:PluginChartNavBar
            x:Name="PART_NavBar"
            Grid.Row="0"
            Margin="0,0,0,4"
            ShowNavBar="{Binding ShowNavBar}"
            ShowAllData="{Binding ShowAllData}"
            NavLabel="{Binding NavLabel}"
            PageSize="{Binding PageSize}"
            FirstClicked="NavBar_FirstClicked"
            PagePrevClicked="NavBar_PagePrevClicked"
            PrevClicked="NavBar_PrevClicked"
            ShowAllToggled="NavBar_ShowAllToggled"
            NextClicked="NavBar_NextClicked"
            PageNextClicked="NavBar_PageNextClicked"
            LastClicked="NavBar_LastClicked" />

        <!-- ===== Row 1 — Chart container ===== -->
        <Grid Grid.Row="1" Name="PART_GridContener">
            <lvc:CartesianChart Name="PART_ChartTimeActivity"
                                DisableAnimations="{Binding DisableAnimations}"
                                AnimationsSpeed="10"
                                Width="{Binding ElementName=PART_GridContener, Path=ActualWidth}"
                                Height="{Binding ElementName=PART_GridContener, Path=ActualHeight}">

                <lvc:CartesianChart.AxisX>
                    <lvc:Axis Name="PART_ChartTimeActivityLabelsX"
                              ShowLabels="{Binding ChartTimeAxis}"
                              MinValue="0"
                              LabelsRotation="{Binding LabelsRotationValue}"
                              FontSize="{DynamicResource FontSize}"
                              FontFamily="{DynamicResource FontFamily}">
                        <lvc:Axis.Separator>
                            <lvc:Separator Step="1" IsEnabled="False" />
                        </lvc:Axis.Separator>
                    </lvc:Axis>
                </lvc:CartesianChart.AxisX>

                <lvc:CartesianChart.AxisY>
                    <lvc:Axis Name="PART_ChartTimeActivityLabelsY"
                              ShowLabels="{Binding ChartTimeOrdinates}"
                              MinValue="0"
                              FontSize="{DynamicResource FontSize}"
                              FontFamily="{DynamicResource FontFamily}">
                        <lvc:Axis.Separator>
                            <lvc:Separator />
                        </lvc:Axis.Separator>
                    </lvc:Axis>
                </lvc:CartesianChart.AxisY>

            </lvc:CartesianChart>
        </Grid>
    </Grid>

</controls:PluginUserControlExtend>