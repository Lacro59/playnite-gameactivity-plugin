<controls:PluginUserControlExtend
        xmlns:controls="clr-namespace:CommonPluginsShared.Controls"
        x:Class="GameActivity.Controls.PluginButton"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:GameActivity.Controls"
        mc:Ignorable="d" d:DesignHeight="40"
        d:DataContext="{d:DesignInstance Type=local:PluginButtonDataContext}">

    <controls:PluginUserControlExtend.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </controls:PluginUserControlExtend.Resources>

    <Button Name="PART_PluginButton"
            Click="PART_PluginButton_Click"
            Style="{StaticResource {x:Type Button}}"
            VerticalAlignment="Stretch"
            ToolTip="{DynamicResource LOCGameActivityTitle}">

        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="2,0">

            <!-- Icon -->
            <TextBlock Text="{Binding Text, Mode=OneWay, FallbackValue='&#xe97f;'}"
                       FontFamily="{DynamicResource FontIcoFont}"
                       FontSize="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=FontSize}"
                       VerticalAlignment="Center" />

            <!-- Detail panel — two stacked lines, compact width -->
            <StackPanel Orientation="Vertical"
                        VerticalAlignment="Center"
                        Margin="5,0,0,0"
                        Visibility="{Binding DisplayDetails, Converter={StaticResource BooleanToVisibilityConverter}}">

                <!-- Last session date — primary, full brightness -->
                <TextBlock Text="{Binding LastActivity, FallbackValue='27/02/2021'}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           LineHeight="13" />

                <!-- Last session duration — secondary, muted -->
                <TextBlock Text="{Binding LastPlaytimeString, FallbackValue='23 minutes'}"
                           FontSize="10"
                           Foreground="{DynamicResource TextBrushDarker}"
                           LineHeight="12" />

            </StackPanel>
        </StackPanel>
    </Button>

</controls:PluginUserControlExtend>