<controls:PluginUserControlExtend
        xmlns:controls="clr-namespace:CommonPluginsShared.Controls"
        x:Class="GameActivity.Controls.PluginChartLog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:GameActivity.Controls"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:livechartscommon="clr-namespace:CommonPluginsControls.LiveChartsCommon"
        mc:Ignorable="d" d:DataContext="{d:DesignInstance Type=local:PluginChartLogDataContext, IsDesignTimeCreatable=True}"
        MinHeight="{Binding RelativeSource={RelativeSource AncestorType=ContentControl}, Path=MinHeight}"
        Height="{Binding ChartLogHeight}"
        MaxHeight="{Binding RelativeSource={RelativeSource AncestorType=ContentControl}, Path=MaxHeight}">

    <controls:PluginUserControlExtend.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- Slide-down animation for the filter bar -->
        <Storyboard x:Key="FilterBarShowAnimation">
            <DoubleAnimation Storyboard.TargetName="PART_FilterBar"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="0" To="1" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="PART_FilterBar"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.18" />
        </Storyboard>

        <Storyboard x:Key="FilterBarHideAnimation">
            <DoubleAnimation Storyboard.TargetName="PART_FilterBar"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="1" To="0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="PART_FilterBar"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.15" />
        </Storyboard>
    </controls:PluginUserControlExtend.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Filter bar — CompactCheckBox for minimal vertical footprint ===== -->
        <Border Grid.Row="0"
                x:Name="PART_FilterBar"
                Style="{DynamicResource FilterCardBorder}"
                Margin="0,0,0,6"
                RenderTransformOrigin="0.5,0"
                Visibility="{Binding UseControls, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Border.RenderTransform>
                <ScaleTransform ScaleY="1" />
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                    <BeginStoryboard Storyboard="{StaticResource FilterBarShowAnimation}" />
                </EventTrigger>
            </Border.Triggers>

            <!-- Grid: fixed label column (col 0, MinWidth=90) aligns checkboxes
                 of both rows at the same X offset regardless of label text length. -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ── Group 1 : Usage ── -->
                <TextBlock Grid.Column="0" Grid.Row="0"
                           Text="{DynamicResource LOCGameActivityGroupUsage}"
                           Style="{DynamicResource ViewColumnLabelText}"
                           VerticalAlignment="Center"
                           MinWidth="90" />

                <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal">
                    <CheckBox Style="{DynamicResource CompactCheckBox}"
                              IsChecked="{Binding DisplayCpu, Mode=OneWay}"
                              Command="{Binding CmdToggleCpu}">
                        <TextBlock Text="{DynamicResource LOCGameActivityLabelCpu}"
                                   Style="{DynamicResource BaseTextBlockStyle}" />
                    </CheckBox>
                    <CheckBox Style="{DynamicResource CompactCheckBox}"
                              IsChecked="{Binding DisplayGpu, Mode=OneWay}"
                              Command="{Binding CmdToggleGpu}">
                        <TextBlock Text="{DynamicResource LOCGameActivityLabelGpu}"
                                   Style="{DynamicResource BaseTextBlockStyle}" />
                    </CheckBox>
                    <CheckBox Style="{DynamicResource CompactCheckBox}"
                              IsChecked="{Binding DisplayRam, Mode=OneWay}"
                              Command="{Binding CmdToggleRam}">
                        <TextBlock Text="{DynamicResource LOCGameActivityLabelRam}"
                                   Style="{DynamicResource BaseTextBlockStyle}" />
                    </CheckBox>
                    <CheckBox Style="{DynamicResource CompactCheckBox}"
                              IsChecked="{Binding DisplayFps, Mode=OneWay}"
                              Command="{Binding CmdToggleFps}">
                        <TextBlock Text="{DynamicResource LOCGameActivityLabelFps}"
                                   Style="{DynamicResource BaseTextBlockStyle}" />
                    </CheckBox>
                </StackPanel>

                <!-- Separator — only shown when DisplayMoreData is true -->
                <Border Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                        Style="{DynamicResource TopSeparatorBorder}"
                        Visibility="{Binding DisplayMoreData, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Margin="0,2,0,2" />

                <!-- ── Group 2 : Temp / Power — hidden by default ── -->
                <TextBlock Grid.Column="0" Grid.Row="2"
                           Text="{DynamicResource LOCGameActivityGroupTempPower}"
                           Style="{DynamicResource ViewColumnLabelText}"
                           Visibility="{Binding DisplayMoreData, Converter={StaticResource BooleanToVisibilityConverter}}"
                           VerticalAlignment="Center"
                           MinWidth="90" />

                <StackPanel Grid.Column="1" Grid.Row="2"
                            Orientation="Horizontal"
                            Visibility="{Binding DisplayMoreData, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <CheckBox Style="{DynamicResource CompactCheckBox}"
                              IsChecked="{Binding DisplayCpuT, Mode=OneWay}"
                              Command="{Binding CmdToggleCpuT}">
                        <TextBlock Text="{DynamicResource LOCGameActivityCpuTemp}"
                                   Style="{DynamicResource BaseTextBlockStyle}" />
                    </CheckBox>
                    <CheckBox Style="{DynamicResource CompactCheckBox}"
                              IsChecked="{Binding DisplayGpuT, Mode=OneWay}"
                              Command="{Binding CmdToggleGpuT}">
                        <TextBlock Text="{DynamicResource LOCGameActivityGpuTemp}"
                                   Style="{DynamicResource BaseTextBlockStyle}" />
                    </CheckBox>
                    <CheckBox Style="{DynamicResource CompactCheckBox}"
                              IsChecked="{Binding DisplayCpuP, Mode=OneWay}"
                              Command="{Binding CmdToggleCpuP}">
                        <TextBlock Text="{DynamicResource LOCGameActivityCpuPower}"
                                   Style="{DynamicResource BaseTextBlockStyle}" />
                    </CheckBox>
                    <CheckBox Style="{DynamicResource CompactCheckBox}"
                              IsChecked="{Binding DisplayGpuP, Mode=OneWay}"
                              Command="{Binding CmdToggleGpuP}">
                        <TextBlock Text="{DynamicResource LOCGameActivityGpuPower}"
                                   Style="{DynamicResource BaseTextBlockStyle}" />
                    </CheckBox>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ===== Chart container ===== -->
        <Border Grid.Row="1" Style="{DynamicResource CardBorder}" Padding="0">
            <Grid Name="PART_GridContener">
                <lvc:CartesianChart LegendLocation="Bottom"
                                    Name="PART_ChartLogActivity"
                                    UpdaterTick="PART_ChartLogActivity_UpdaterTick"
                                    DisableAnimations="{Binding DisableAnimations}"
                                    AnimationsSpeed="10"
                                    Width="{Binding ElementName=PART_GridContener, Path=ActualWidth}"
                                    Height="{Binding ElementName=PART_GridContener, Path=ActualHeight}">

                    <lvc:CartesianChart.ChartLegend>
                        <!-- Legend hidden: filter bar checkboxes serve as interactive legend -->
                        <lvc:DefaultLegend Height="2" Visibility="Hidden" />
                    </lvc:CartesianChart.ChartLegend>

                    <lvc:CartesianChart.DataTooltip>
                        <livechartscommon:CustomerToolTipForMultipleTime />
                    </lvc:CartesianChart.DataTooltip>

                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Name="PART_ChartLogActivityLabelsX"
                                  ShowLabels="{Binding ChartLogAxis}"
                                  MinValue="0"
                                  LabelsRotation="{Binding LabelsRotationValue}"
                                  FontSize="{DynamicResource FontSizeSmall}"
                                  FontFamily="{DynamicResource FontFamily}">
                            <lvc:Axis.Separator>
                                <lvc:Separator Step="1" />
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisX>

                    <lvc:CartesianChart.AxisY>
                        <!-- Y0 (left): CPU / GPU / RAM usage in % -->
                        <lvc:Axis Name="PART_ChartLogActivityLabelsY"
                                  ShowLabels="{Binding ChartLogOrdinates}"
                                  MinValue="0"
                                  FontSize="{DynamicResource FontSizeSmall}"
                                  FontFamily="{DynamicResource FontFamily}">
                            <lvc:Axis.Separator>
                                <lvc:Separator />
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                        <!-- Y1 (right): FPS + Temp °C + Power W — non-% values share this axis -->
                        <lvc:Axis Name="PART_ChartLogActivityLabelsY_FPS"
                                  ShowLabels="{Binding ChartLogOrdinates}"
                                  MinValue="0"
                                  FontSize="{DynamicResource FontSizeSmall}"
                                  FontFamily="{DynamicResource FontFamily}"
                                  Position="RightTop">
                            <lvc:Axis.Separator>
                                <lvc:Separator IsEnabled="False" />
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisY>

                </lvc:CartesianChart>
            </Grid>
        </Border>

    </Grid>

    <!-- DataTriggers: animate filter bar show/hide on UseControls change -->
    <controls:PluginUserControlExtend.Style>
        <Style TargetType="controls:PluginUserControlExtend">
            <Style.Triggers>
                <DataTrigger Binding="{Binding UseControls}" Value="False">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Storyboard="{StaticResource FilterBarHideAnimation}" />
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard Storyboard="{StaticResource FilterBarShowAnimation}" />
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </controls:PluginUserControlExtend.Style>

</controls:PluginUserControlExtend>